{
  "name": "blackbox-mcp",
  "version": "0.1.2",
  "description": "MCP server for AI agents to interact with the BlackBox privacy protocol — deposit, claim keys, withdraw across chains via 3-of-5 distributed threshold cryptography",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blackbox-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "blockchain",
    "privacy",
    "dkg",
    "threshold-cryptography",
    "cross-chain",
    "ethereum",
    "solana",
    "ecdsa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/InterNullOrg/blackbox_mcp.git"
  },
  "homepage": "https://theblackbox.network",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "ethers": "^5.7.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
